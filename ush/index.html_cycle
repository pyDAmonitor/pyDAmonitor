<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>pyDAmonitor</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@300;400;600&display=swap');

    :root {
      --bg:        #ffffff;
      --surface:   #f6f8fa;
      --border:    #d0d7de;
      --accent:    #0969da;
      --accent2:   #1a7f37;
      --accent3:   #cf222e;
      --text:      #24292f;
      --muted:     #57606a;
      --heading:   #24292f;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'IBM Plex Sans', sans-serif;
      font-size: 18px;
      line-height: 1.6;
      min-height: 100vh;
    }

    /* ── Header ── */
    header {
      border-bottom: 1px solid var(--border);
      padding: 18px 32px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      position: sticky;
      top: 0;
      background: var(--bg);
      z-index: 100;
    }

    header .logo {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 24px;
      font-weight: 600;
      color: var(--heading);
      letter-spacing: -0.5px;
    }

    header .cycle {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 18px;
      color: var(--muted);
    }

    /* ── Layout ── */
    main {
      max-width: 1100px;
      margin: 0 auto;
      padding: 36px 32px 64px;
      display: flex;
      flex-direction: column;
      gap: 40px;
    }

    /* ── Section ── */
    section {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      animation: fadeUp 0.4s ease both;
    }

    section:nth-child(1) { animation-delay: 0.05s; }
    section:nth-child(2) { animation-delay: 0.12s; }
    section:nth-child(3) { animation-delay: 0.19s; }
    section:nth-child(4) { animation-delay: 0.26s; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .section-header {
      padding: 14px 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .section-header .num {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 16px;
      color: var(--muted);
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 1px 6px;
    }

    .section-header h2 {
      font-size: 16px;
      font-weight: 600;
      color: var(--heading);
      letter-spacing: 0.3px;
      text-transform: uppercase;
    }

    .section-body { padding: 20px; }

    /* ── Grid of links ── */
    .link-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 10px;
    }

    .link-card {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      border: 1px solid var(--border);
      border-radius: 6px;
      text-decoration: none;
      color: var(--text);
      background: var(--bg);
      transition: border-color 0.15s, background 0.15s, color 0.15s;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 14px;
      word-break: break-all;
    }

    .link-card:hover {
      border-color: var(--accent);
      background: color-mix(in srgb, var(--accent) 6%, transparent);
      color: var(--accent);
    }

    .link-card:hover .icon { color: var(--accent); }

    .icon {
      flex-shrink: 0;
      width: 16px;
      height: 16px;
      color: var(--muted);
      transition: color 0.15s;
    }

    /* Accent variants */
    .accent-green .link-card:hover { border-color: var(--accent2); background: color-mix(in srgb, var(--accent2) 6%, transparent); color: var(--accent2); }
    .accent-green .link-card:hover .icon { color: var(--accent2); }

    .accent-red .link-card:hover { border-color: var(--accent3); background: color-mix(in srgb, var(--accent3) 6%, transparent); color: var(--accent3); }
    .accent-red .link-card:hover .icon { color: var(--accent3); }

    /* ── Footer ── */
    footer {
      text-align: center;
      padding: 24px;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 14px;
      color: var(--muted);
      border-top: 1px solid var(--border);
    }
  </style>
</head>
<body>

<header>
  <div class="logo">pyDAmonitor 2024050600</div>
  <div class="cycle">
    <input id="cycle-input" type="text" value="2024050600" maxlength="10"
      style="font-family:'IBM Plex Mono',monospace;font-size:16px;color:var(--muted);border:1px solid var(--border);border-radius:4px;padding:3px 8px;text-align:center;width:130px;outline:none;"
      onkeydown="if(event.key==='Enter') goCycle()" />
    <button onclick="goCycle()"
      style="font-family:'IBM Plex Mono',monospace;font-size:14px;padding:4px 12px;margin-left:6px;border:1px solid var(--border);border-radius:4px;background:var(--surface);color:var(--text);cursor:pointer;">
      Go
    </button>
    <button onclick="goLatest()"
      style="font-family:'IBM Plex Mono',monospace;font-size:14px;padding:4px 12px;margin-left:6px;border:1px solid var(--border);border-radius:4px;background:var(--surface);color:var(--text);cursor:pointer;">
      Latest
    </button>
    <button onclick="goRepoDocs()"
      style="font-family:'IBM Plex Mono',monospace;font-size:14px;padding:4px 12px;margin-left:6px;border:1px solid var(--border);border-radius:4px;background:var(--surface);color:var(--text);cursor:pointer;">
      Documents
    </button>
  </div>
</header>

<script>
  function goCycle() {
    const val = document.getElementById('cycle-input').value.trim();
    if (val) window.open('../' + val, '_blank');
  }
  function goLatest() {
    window.open('../', '_blank');
  }
  function goRepoDocs() {
    window.open('https://pydamonitor.github.io/docs/intro.html')
  }
</script>

<main>

  <!-- ── Section 1: Obs Count Time Series ── -->
  <section>
    <div class="section-header">
      <span class="num">01</span>
      <h2>Obs Count Time Series</h2>
    </div>
    <div class="section-body">
      <div class="link-grid">
        <a class="link-card" href="obs_count_tseries_adpsfc_ps.png" target="_blank">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="14" height="14" rx="2"/><polyline points="4,10 7,6 9,8 12,4"/></svg>
          adpsfc_ps
        </a>
        <a class="link-card" href="obs_count_tseries_adpsfc_q.png" target="_blank">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="14" height="14" rx="2"/><polyline points="4,10 7,6 9,8 12,4"/></svg>
          adpsfc_q
        </a>
        <a class="link-card" href="obs_count_tseries_adpsfc_t.png" target="_blank">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="14" height="14" rx="2"/><polyline points="4,10 7,6 9,8 12,4"/></svg>
          adpsfc_t
        </a>
        <a class="link-card" href="obs_count_tseries_adpsfc_uv.png" target="_blank">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="14" height="14" rx="2"/><polyline points="4,10 7,6 9,8 12,4"/></svg>
          adpsfc_uv
        </a>
        <a class="link-card" href="obs_count_tseries_adpupa.png" target="_blank">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="14" height="14" rx="2"/><polyline points="4,10 7,6 9,8 12,4"/></svg>
          adpupa
        </a>
        <a class="link-card" href="obs_count_tseries_aircar.png" target="_blank">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="14" height="14" rx="2"/><polyline points="4,10 7,6 9,8 12,4"/></svg>
          aircar
        </a>
        <a class="link-card" href="obs_count_tseries_sfcshp.png" target="_blank">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="14" height="14" rx="2"/><polyline points="4,10 7,6 9,8 12,4"/></svg>
          sfcshp
        </a>
      </div>
    </div>
  </section>

  <!-- ── Section 2: Obs Count Text Files ── -->
  <section class="accent-green">
    <div class="section-header">
      <span class="num">02</span>
      <h2>Obs Count Text Files</h2>
    </div>
    <div class="section-body">
      <div class="link-grid">
        <a class="link-card" href="minimization.txt" target="_blank">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 2h7l3 3v9H3z"/><polyline points="10,2 10,5 13,5"/><line x1="5" y1="8" x2="11" y2="8"/><line x1="5" y1="11" x2="9" y2="11"/></svg>
          minimization.txt
        </a>
        <a class="link-card" href="obs_count.txt" target="_blank">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 2h7l3 3v9H3z"/><polyline points="10,2 10,5 13,5"/><line x1="5" y1="8" x2="11" y2="8"/><line x1="5" y1="11" x2="9" y2="11"/></svg>
          obs_count.txt
        </a>
        <a class="link-card" href="nonvar_cloud_out.txt" target="_blank">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 2h7l3 3v9H3z"/><polyline points="10,2 10,5 13,5"/><line x1="5" y1="8" x2="11" y2="8"/><line x1="5" y1="11" x2="9" y2="11"/></svg>
          nonvar_cloud_out.txt
        </a>
      </div>
    </div>
  </section>

  <!-- ── Section 3: Minimization Process ── -->
  <section>
    <div class="section-header">
      <span class="num">03</span>
      <h2>Minimization Process</h2>
    </div>
    <div class="section-body">
      <div class="link-grid">
        <a class="link-card" href="cost1.png" target="_blank">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="14" height="14" rx="2"/><polyline points="4,10 7,6 9,8 12,4"/></svg>
          cost function
        </a>
        <a class="link-card" href="resnorm1.png" target="_blank">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="14" height="14" rx="2"/><polyline points="4,10 7,6 9,8 12,4"/></svg>
          gradient
        </a>
      </div>
    </div>
  </section>

  <!-- ── Section 4: JEDI Log Files & YAML ── -->
  <section class="accent-red">
    <div class="section-header">
      <span class="num">04</span>
      <h2>JEDI Log Files &amp; YAML Configurations</h2>
    </div>
    <div class="section-body">
      <div class="link-grid">
        <a class="link-card" href="jedivar.yaml" target="_blank">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 2h7l3 3v9H3z"/><polyline points="10,2 10,5 13,5"/><line x1="5" y1="8" x2="7" y2="8"/><line x1="5" y1="11" x2="8" y2="11"/></svg>
          jedivar.yaml
        </a>
        <a class="link-card" href="jedivar.pass2.yaml" target="_blank">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 2h7l3 3v9H3z"/><polyline points="10,2 10,5 13,5"/><line x1="5" y1="8" x2="7" y2="8"/><line x1="5" y1="11" x2="8" y2="11"/></svg>
          jedivar.pass2.yaml
        </a>
        <a class="link-card" href="log.out" target="_blank">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="14" height="10" rx="2"/><line x1="4" y1="7" x2="12" y2="7"/><line x1="4" y1="10" x2="8" y2="10"/></svg>
          log.out
        </a>
        <a class="link-card" href="log.pass2.out" target="_blank">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="14" height="10" rx="2"/><line x1="4" y1="7" x2="12" y2="7"/><line x1="4" y1="10" x2="8" y2="10"/></svg>
          log.pass2.out
        </a>
      </div>
    </div>
  </section>

</main>

<footer>Powered by <a href="https://pydamonitor.github.io/docs/intro.html" target="_blank">pyDAmonitor</a></footer>

</body>
</html>
